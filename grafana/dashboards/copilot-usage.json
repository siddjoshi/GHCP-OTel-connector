{
  "annotations": { "list": [] },
  "description": "Overview of GitHub Copilot usage — event rates, latency, operations, and recent activity from OpenTelemetry traces and logs",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "Copilot Insights →", "url": "/d/copilot-insights", "type": "link", "icon": "bolt", "targetBlank": false },
    { "title": "← App Overview", "url": "/d/app-overview", "type": "link", "icon": "apps", "targetBlank": false }
  ],
  "panels": [
    {
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "type": "text",
      "title": "",
      "options": {
        "mode": "markdown",
        "content": "## GitHub Copilot — Usage Overview\nReal-time view of Copilot activity captured via OpenTelemetry. Metrics are derived from **Tempo span-metrics** (rates & latency), **Loki** (logs), and **Tempo** (traces). Use the **Service** filter to scope to a specific Copilot service."
      }
    },

    {
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 3 },
      "id": 1,
      "type": "stat",
      "title": "Total Events",
      "description": "Total Copilot span events in the selected time range",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10000 }] },
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(increase(traces_spanmetrics_calls_total{service=~\"$service\"}[$__range])) OR vector(0)", "legendFormat": "", "refId": "A" }]
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 3 },
      "id": 2,
      "type": "stat",
      "title": "Events / min",
      "description": "Current rate of Copilot events per minute",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] },
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(rate(traces_spanmetrics_calls_total{service=~\"$service\"}[5m])) * 60 OR vector(0)", "legendFormat": "", "refId": "A" }]
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 3 },
      "id": 3,
      "type": "stat",
      "title": "Error Events",
      "description": "Total events with error status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 50 }] },
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(increase(traces_spanmetrics_calls_total{service=~\"$service\", status_code=\"STATUS_CODE_ERROR\"}[$__range])) OR vector(0)", "legendFormat": "", "refId": "A" }]
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 3 },
      "id": 4,
      "type": "stat",
      "title": "Avg Response Latency",
      "description": "Average span duration across all Copilot operations",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 2 }, { "color": "red", "value": 10 }] },
          "unit": "s",
          "noValue": "N/A"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(rate(traces_spanmetrics_latency_sum{service=~\"$service\"}[$__rate_interval])) / sum(rate(traces_spanmetrics_latency_count{service=~\"$service\"}[$__rate_interval]))", "legendFormat": "", "refId": "A" }]
    },

    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "id": 10,
      "type": "timeseries",
      "title": "Event Rate by Operation",
      "description": "Rate of Copilot events broken down by span operation name (chat, completion, etc.)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never", "axisBorderShow": false, "stacking": { "mode": "none" } },
          "unit": "ops"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean", "lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "expr": "sum by (span_name) (rate(traces_spanmetrics_calls_total{service=~\"$service\"}[$__rate_interval]))", "legendFormat": "{{span_name}}", "refId": "A" }]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "id": 11,
      "type": "timeseries",
      "title": "Error Rate Over Time",
      "description": "Rate of error vs ok events over time",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never", "axisBorderShow": false },
          "unit": "ops"
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*ERROR.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": ".*OK.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "sum by (status_code) (rate(traces_spanmetrics_calls_total{service=~\"$service\"}[$__rate_interval]))", "legendFormat": "{{status_code}}", "refId": "A" }
      ]
    },

    {
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "id": 14,
      "type": "piechart",
      "title": "Events by Operation",
      "description": "Distribution of Copilot operations (completion, chat, etc.)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }, "tooltip": { "mode": "multi" }, "pieType": "donut", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [{ "expr": "sum by (span_name) (increase(traces_spanmetrics_calls_total{service=~\"$service\"}[$__range]))", "legendFormat": "{{span_name}}", "refId": "A", "instant": true }]
    },
    {
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "id": 15,
      "type": "piechart",
      "title": "Events by Status",
      "description": "Proportion of successful vs error events",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*ERROR.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": ".*OK.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": ".*UNSET.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }, "tooltip": { "mode": "multi" }, "pieType": "donut", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [{ "expr": "sum by (status_code) (increase(traces_spanmetrics_calls_total{service=~\"$service\"}[$__range]))", "legendFormat": "{{status_code}}", "refId": "A", "instant": true }]
    },
    {
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "id": 16,
      "type": "piechart",
      "title": "Events by Service",
      "description": "Distribution of events across Copilot services",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }, "tooltip": { "mode": "multi" }, "pieType": "donut", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [{ "expr": "sum by (service) (increase(traces_spanmetrics_calls_total{service=~\"$service\"}[$__range]))", "legendFormat": "{{service}}", "refId": "A", "instant": true }]
    },

    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 23 },
      "id": 101,
      "type": "text",
      "title": "",
      "options": { "mode": "markdown", "content": "---\n### Latency Analysis" }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "id": 17,
      "type": "timeseries",
      "title": "Response Latency Percentiles",
      "description": "P50 / P95 / P99 latency of Copilot operations",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" },
          "unit": "s"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "P50" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "P95" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "P99" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(traces_spanmetrics_latency_bucket{service=~\"$service\"}[$__rate_interval])))", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_spanmetrics_latency_bucket{service=~\"$service\"}[$__rate_interval])))", "legendFormat": "P95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(traces_spanmetrics_latency_bucket{service=~\"$service\"}[$__rate_interval])))", "legendFormat": "P99", "refId": "C" }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "id": 18,
      "type": "timeseries",
      "title": "Latency by Operation",
      "description": "Average latency broken out by Copilot operation (span name)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" },
          "unit": "s"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "expr": "sum by (span_name) (rate(traces_spanmetrics_latency_sum{service=~\"$service\"}[$__rate_interval])) / sum by (span_name) (rate(traces_spanmetrics_latency_count{service=~\"$service\"}[$__rate_interval]))", "legendFormat": "{{span_name}}", "refId": "A" }]
    },

    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 33 },
      "id": 102,
      "type": "text",
      "title": "",
      "options": { "mode": "markdown", "content": "---\n### Log Volume" }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 },
      "id": 20,
      "type": "timeseries",
      "title": "Log Volume by Event Type",
      "description": "Copilot log event volume split by event type",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 20, "showPoints": "never", "stacking": { "mode": "normal" } },
          "unit": "short"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "expr": "sum by (event_name) (count_over_time({service_name=~\"$service\"} | event_name != \"\" [$__auto]))", "legendFormat": "{{event_name}}", "refId": "A" }]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 },
      "id": 21,
      "type": "timeseries",
      "title": "Log Volume by Service",
      "description": "Overall log volume per Copilot service",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 20, "showPoints": "never", "stacking": { "mode": "normal" } },
          "unit": "short"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "expr": "sum by (service_name) (count_over_time({service_name=~\"$service\"} [$__auto]))", "legendFormat": "{{service_name}}", "refId": "A" }]
    },

    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 43 },
      "id": 103,
      "type": "text",
      "title": "",
      "options": { "mode": "markdown", "content": "---\n### Recent Copilot Traces (Tempo)\nClick a **Trace ID** to open the full span waterfall." }
    },
    {
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 45 },
      "id": 30,
      "type": "table",
      "title": "Recent Traces",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [{
        "datasource": { "type": "tempo", "uid": "tempo" },
        "queryType": "traceqlSearch",
        "limit": 30,
        "filters": [
          { "id": "service-name", "tag": "service.name", "operator": "=~", "value": ["$service"], "scope": "resource" },
          { "id": "status", "tag": "status", "operator": "=", "scope": "intrinsic" }
        ]
      }],
      "fieldConfig": { "defaults": {} },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Start time", "desc": true }] }
    },

    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 55 },
      "id": 104,
      "type": "text",
      "title": "",
      "options": { "mode": "markdown", "content": "---\n### Recent Copilot Logs (Loki)\nStructured logs from the Copilot OTLP pipeline. Click a **TraceID** link to jump to the corresponding trace." }
    },
    {
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 57 },
      "id": 31,
      "type": "logs",
      "title": "Copilot Logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "{service_name=~\"$service\"}",
        "refId": "A"
      }],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ],

  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(traces_spanmetrics_calls_total, service)",
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "multi": true,
        "refresh": 2,
        "sort": 1
      }
    ]
  },

  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["copilot", "opentelemetry", "usage"],
  "title": "GitHub Copilot - Usage Overview",
  "uid": "copilot-usage",
  "version": 1
}
