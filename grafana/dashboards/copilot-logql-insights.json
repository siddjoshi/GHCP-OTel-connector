      "id": 1,
      "type": "text",
      "title": "",
      "options": {
        "mode": "markdown",
        "content": "## GitHub Copilot — LogQL Insights\nAdvanced analytics derived from Copilot OpenTelemetry data. Covers **activity volume**, **model & token analysis**, **latency & TTFT**, **tool call analytics**, **top-N rankings**, and **error intelligence**."
      }
    },

    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 3 },
      "id": 2,
      "type": "text",
      "title": "",
      "options": { "mode": "markdown", "content": "---\n### Volume & Activity Overview" }
    },
    {
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 5 },
      "id": 10,
      "type": "stat",
      "title": "Total Log Events",
      "description": "Total Copilot log entries in time range",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] },
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [{ "expr": "sum(count_over_time({service_name=~\"$service\"} [$__range]))", "legendFormat": "", "refId": "A" }]
    },
    {
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 5 },
      "id": 11,
      "type": "stat",
      "title": "Inference Events",
      "description": "Total gen_ai.client.inference events",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "orange", "value": null }] },
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [{ "expr": "sum(count_over_time({service_name=~\"$service\"} | event_name = `gen_ai.client.inference.operation.details` [$__range]))", "legendFormat": "", "refId": "A" }]
    },
    {
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 5 },
      "id": 12,
      "type": "stat",
      "title": "Agent Turns",
      "description": "Total copilot_chat.agent.turn events",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [{ "expr": "sum(count_over_time({service_name=~\"$service\"} | event_name = `copilot_chat.agent.turn` [$__range]))", "legendFormat": "", "refId": "A" }]
    },
    {
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 5 },
      "id": 13,
      "type": "stat",
      "title": "Tool Calls",
      "description": "Total copilot_chat.tool.call events",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "purple", "value": null }] },
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [{ "expr": "sum(count_over_time({service_name=~\"$service\"} | event_name = `copilot_chat.tool.call` [$__range]))", "legendFormat": "", "refId": "A" }]
    },
    {
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 5 },
      "id": 14,
      "type": "stat",
      "title": "Sessions",
      "description": "Total Copilot chat sessions (from Prometheus counter)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "yellow", "value": null }] },
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(increase(copilot_chat_session_count_total{job=~\"$service\"}[$__range])) OR vector(0)", "legendFormat": "", "refId": "A" }]
    },
    {
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 5 },
      "id": 15,
      "type": "stat",
      "title": "Span Events",
      "description": "Total span events from Tempo span-metrics",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(increase(traces_spanmetrics_calls_total{service=~\"$service\"}[$__range])) OR vector(0)", "legendFormat": "", "refId": "A" }]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 16,
      "type": "timeseries",
      "title": "Event Rate by Type (Loki)",
      "description": "Rate of Copilot log events by event type",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never", "stacking": { "mode": "normal" } },
          "unit": "short"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "expr": "sum by (event_name) (count_over_time({service_name=~\"$service\"} | event_name != \"\" [$__auto]))", "legendFormat": "{{event_name}}", "refId": "A" }]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 17,
      "type": "timeseries",
      "title": "Span Rate by Operation (Prometheus)",
      "description": "Rate of span events by operation name from Tempo span-metrics",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never" },
          "unit": "ops"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "expr": "sum by (span_name) (rate(traces_spanmetrics_calls_total{service=~\"$service\"}[$__rate_interval]))", "legendFormat": "{{span_name}}", "refId": "A" }]
    },

    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 17 },
      "id": 3,
      "type": "text",
      "title": "",
      "options": { "mode": "markdown", "content": "---\n### AI Model & Token Analytics\nToken consumption and inference distribution across AI models. Data from both Loki structured metadata and Prometheus OTel metrics." }
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 19 },
      "id": 20,
      "type": "stat",
      "title": "Total Input Tokens",
      "description": "Sum of input tokens (from Loki structured metadata)",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] },
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [{ "expr": "sum(sum_over_time({service_name=~\"$service\"} | gen_ai_usage_input_tokens != \"\" | unwrap gen_ai_usage_input_tokens [$__range]))", "legendFormat": "", "refId": "A" }]
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 19 },
      "id": 21,
      "type": "stat",
      "title": "Total Output Tokens",
      "description": "Sum of output tokens (from Loki structured metadata)",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "purple", "value": null }] },
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [{ "expr": "sum(sum_over_time({service_name=~\"$service\"} | gen_ai_usage_output_tokens != \"\" | unwrap gen_ai_usage_output_tokens [$__range]))", "legendFormat": "", "refId": "A" }]
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 19 },
      "id": 22,
      "type": "stat",
      "title": "Total Input Tokens (Prom)",
      "description": "Sum of input tokens from Prometheus gen_ai_client_token_usage histogram",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] },
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(increase(gen_ai_client_token_usage_sum{job=~\"$service\", gen_ai_token_type=\"input\"}[$__range])) OR vector(0)", "legendFormat": "", "refId": "A" }]
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 19 },
      "id": 23,
      "type": "stat",
      "title": "Total Output Tokens (Prom)",
      "description": "Sum of output tokens from Prometheus gen_ai_client_token_usage histogram",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "purple", "value": null }] },
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(increase(gen_ai_client_token_usage_sum{job=~\"$service\", gen_ai_token_type=\"output\"}[$__range])) OR vector(0)", "legendFormat": "", "refId": "A" }]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 24,
      "type": "timeseries",
      "title": "Token Usage Over Time (Loki)",
      "description": "Input vs output token consumption over time from Loki structured metadata",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never" },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Input Tokens" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Output Tokens" }, "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "sum(sum_over_time({service_name=~\"$service\"} | gen_ai_usage_input_tokens != \"\" | unwrap gen_ai_usage_input_tokens [$__auto]))", "legendFormat": "Input Tokens", "refId": "A" },
        { "expr": "sum(sum_over_time({service_name=~\"$service\"} | gen_ai_usage_output_tokens != \"\" | unwrap gen_ai_usage_output_tokens [$__auto]))", "legendFormat": "Output Tokens", "refId": "B" }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 25,
      "type": "piechart",
      "title": "Inference Calls by Model (Loki)",
      "description": "Distribution of inference events per AI model from Loki structured metadata",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }, "tooltip": { "mode": "multi" }, "pieType": "donut", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [{ "expr": "sum by (gen_ai_request_model) (count_over_time({service_name=~\"$service\"} | gen_ai_request_model != \"\" [$__range]))", "legendFormat": "{{gen_ai_request_model}}", "refId": "A" }]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "id": 26,
      "type": "barchart",
      "title": "Token Usage by Model (Loki)",
      "description": "Input and output tokens consumed per AI model",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*input.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": ".*output.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" }, "orientation": "horizontal", "stacking": "normal", "barWidth": 0.8, "groupWidth": 0.7 },
      "targets": [
        { "expr": "sum by (gen_ai_request_model) (sum_over_time({service_name=~\"$service\"} | gen_ai_request_model != \"\" | gen_ai_usage_input_tokens != \"\" | unwrap gen_ai_usage_input_tokens [$__range]))", "legendFormat": "input: {{gen_ai_request_model}}", "refId": "A" },
        { "expr": "sum by (gen_ai_request_model) (sum_over_time({service_name=~\"$service\"} | gen_ai_request_model != \"\" | gen_ai_usage_output_tokens != \"\" | unwrap gen_ai_usage_output_tokens [$__range]))", "legendFormat": "output: {{gen_ai_request_model}}", "refId": "B" }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "id": 27,
      "type": "timeseries",
      "title": "Token Usage by Model Over Time (Prom)",
      "description": "Token consumption rate by model and type from Prometheus gen_ai_client_token_usage",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" },
          "unit": "short"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "sum by (gen_ai_request_model) (rate(gen_ai_client_token_usage_sum{job=~\"$service\", gen_ai_token_type=\"input\"}[$__rate_interval]))", "legendFormat": "input: {{gen_ai_request_model}}", "refId": "A" },
        { "expr": "sum by (gen_ai_request_model) (rate(gen_ai_client_token_usage_sum{job=~\"$service\", gen_ai_token_type=\"output\"}[$__rate_interval]))", "legendFormat": "output: {{gen_ai_request_model}}", "refId": "B" }
      ]
    },

    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 39 },
      "id": 4,
      "type": "text",
      "title": "",
      "options": { "mode": "markdown", "content": "---\n### Performance & Latency Deep-Dive\nLatency percentiles, time-to-first-token (TTFT), operation duration, and throughput correlation." }
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 41 },
      "id": 30,
      "type": "stat",
      "title": "Avg Latency (P50)",
      "description": "Median span latency from Tempo span-metrics",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 2 }, { "color": "red", "value": 10 }] },
          "unit": "s",
          "noValue": "N/A"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "histogram_quantile(0.50, sum by (le) (rate(traces_spanmetrics_latency_bucket{service=~\"$service\"}[$__rate_interval])))", "legendFormat": "", "refId": "A" }]
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 41 },
      "id": 31,
      "type": "stat",
      "title": "P95 Latency",
      "description": "95th percentile span latency",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] },
          "unit": "s",
          "noValue": "N/A"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_spanmetrics_latency_bucket{service=~\"$service\"}[$__rate_interval])))", "legendFormat": "", "refId": "A" }]
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 41 },
      "id": 32,
      "type": "stat",
      "title": "P99 Latency",
      "description": "99th percentile span latency (worst-case tail)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 30 }] },
          "unit": "s",
          "noValue": "N/A"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "histogram_quantile(0.99, sum by (le) (rate(traces_spanmetrics_latency_bucket{service=~\"$service\"}[$__rate_interval])))", "legendFormat": "", "refId": "A" }]
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 41 },
      "id": 33,
      "type": "stat",
      "title": "Avg TTFT",
      "description": "Average time-to-first-token across all models",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 2 }, { "color": "red", "value": 5 }] },
          "unit": "s",
          "noValue": "N/A"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(rate(copilot_chat_time_to_first_token_sum{job=~\"$service\"}[$__rate_interval])) / sum(rate(copilot_chat_time_to_first_token_count{job=~\"$service\"}[$__rate_interval]))", "legendFormat": "", "refId": "A" }]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 45 },
      "id": 34,
      "type": "timeseries",
      "title": "Latency Percentiles Over Time",
      "description": "P50, P95, P99 latency trends from Tempo span-metrics",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" },
          "unit": "s"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "P50" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "P95" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "P99" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
