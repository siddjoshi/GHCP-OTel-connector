{
  "annotations": { "list": [] },
  "description": "Unified view of traces, logs, and metrics from applications sending OpenTelemetry data",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "Traces Explorer", "url": "/d/traces-explorer", "type": "link", "icon": "bolt", "targetBlank": false },
    { "title": "Logs Explorer", "url": "/d/logs-explorer", "type": "link", "icon": "file-alt", "targetBlank": false },
    { "title": "Metrics Explorer", "url": "/d/metrics-explorer", "type": "link", "icon": "graph-bar", "targetBlank": false }
  ],
  "panels": [
    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "type": "text",
      "title": "",
      "options": {
        "mode": "markdown",
        "content": "## Application Observability Overview\nThis dashboard shows traces, logs, and metrics received by the OpenTelemetry Collector. Use the **Service** filter at the top to drill down into a specific application."
      }
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 2 },
      "id": 1,
      "type": "stat",
      "title": "Total Spans Received (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 10000 }] },
          "unit": "short"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(increase(otelcol_receiver_accepted_spans_total[5m]))", "legendFormat": "" }]
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 2 },
      "id": 2,
      "type": "stat",
      "title": "Total Metric Points (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }, { "color": "yellow", "value": 5000 }, { "color": "red", "value": 50000 }] },
          "unit": "short"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(increase(otelcol_receiver_accepted_metric_points_total[5m]))", "legendFormat": "" }]
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 2 },
      "id": 3,
      "type": "stat",
      "title": "Total Log Records (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "purple", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 10000 }] },
          "unit": "short"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(increase(otelcol_receiver_accepted_log_records_total[5m]))", "legendFormat": "" }]
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 2 },
      "id": 4,
      "type": "stat",
      "title": "Dropped / Refused",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 100 }] },
          "unit": "short"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(increase(otelcol_receiver_refused_spans_total[5m])) + sum(increase(otelcol_receiver_refused_metric_points_total[5m])) + sum(increase(otelcol_receiver_refused_log_records_total[5m]))", "legendFormat": "" }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "type": "timeseries",
      "title": "Spans Received / sec  (by service)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never", "axisBorderShow": false },
          "unit": "ops"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "sum by (service_name) (rate(otelcol_receiver_accepted_spans_total[1m]))", "legendFormat": "{{service_name}}" }]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "type": "timeseries",
      "title": "Metric Points Received / sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never", "axisBorderShow": false },
          "unit": "ops"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "sum by (receiver) (rate(otelcol_receiver_accepted_metric_points_total[1m]))", "legendFormat": "{{receiver}}" }]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 12,
      "type": "timeseries",
      "title": "Log Records Received / sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never", "axisBorderShow": false },
          "unit": "ops"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "sum by (receiver) (rate(otelcol_receiver_accepted_log_records_total[1m]))", "legendFormat": "{{receiver}}" }]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 13,
      "type": "timeseries",
      "title": "Exporter Send Rate (spans, metrics, logs)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never", "axisBorderShow": false },
          "unit": "ops"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "rate(otelcol_exporter_sent_spans_total[1m])", "legendFormat": "spans → {{exporter}}" },
        { "expr": "rate(otelcol_exporter_sent_metric_points_total[1m])", "legendFormat": "metrics → {{exporter}}" },
        { "expr": "rate(otelcol_exporter_sent_log_records_total[1m])", "legendFormat": "logs → {{exporter}}" }
      ]
    },
    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 22 },
      "id": 101,
      "type": "text",
      "title": "",
      "options": { "mode": "markdown", "content": "---\n### Recent Traces (Tempo)" }
    },
    {
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "id": 20,
      "type": "table",
      "title": "Recent Traces",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [{
        "queryType": "traceqlSearch",
        "limit": 20,
        "filters": [
          { "id": "status", "tag": "status", "operator": "=", "scope": "intrinsic" }
        ]
      }],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": { "showHeader": true, "footer": { "show": false } }
    },
    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 34 },
      "id": 102,
      "type": "text",
      "title": "",
      "options": { "mode": "markdown", "content": "---\n### Recent Logs (Loki)" }
    },
    {
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 36 },
      "id": 30,
      "type": "logs",
      "title": "Application Logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "{job=~\".+\"} | json",
        "refId": "A"
      }],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["opentelemetry", "overview", "vscode"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Application Overview",
  "uid": "app-overview",
  "version": 1
}
