{
  "annotations": { "list": [] },
  "description": "Deep analytics for GitHub Copilot — AI model performance, token usage, tool calls, error intelligence, and detailed trace/log exploration",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "← Copilot Usage", "url": "/d/copilot-usage", "type": "link", "icon": "apps", "targetBlank": false },
    { "title": "Advanced Metrics", "url": "/d/copilot-advanced-metrics", "type": "link", "icon": "graph-bar", "targetBlank": false },
    { "title": "Prompt Explorer", "url": "/d/copilot-prompt-response", "type": "link", "icon": "file-alt", "targetBlank": false },
    { "title": "Traces Explorer", "url": "/d/traces-explorer", "type": "link", "icon": "bolt", "targetBlank": false },
    { "title": "Logs Explorer", "url": "/d/logs-explorer", "type": "link", "icon": "file-alt", "targetBlank": false }
  ],
  "panels": [
    {
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "type": "text",
      "title": "",
      "options": {
        "mode": "markdown",
        "content": "## GitHub Copilot — Smart Insights\nDeep-dive analytics derived from Copilot OpenTelemetry data. Includes **AI model & token analysis** (from Loki structured metadata), **performance profiling** (from Tempo span-metrics), **tool call analysis**, and **error intelligence**."
      }
    },

    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 3 },
      "id": 101,
      "type": "text",
      "title": "",
      "options": { "mode": "markdown", "content": "---\n### AI Model & Token Analytics" }
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 5 },
      "id": 1,
      "type": "stat",
      "title": "Total Input Tokens",
      "description": "Sum of input tokens across all events with gen_ai_usage_input_tokens",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] },
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [{ "expr": "sum(sum_over_time({service_name=~\"$service\"} | gen_ai_usage_input_tokens != \"\" | unwrap gen_ai_usage_input_tokens [$__range]))", "legendFormat": "", "refId": "A" }]
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 5 },
      "id": 2,
      "type": "stat",
      "title": "Total Output Tokens",
      "description": "Sum of output tokens across all events with gen_ai_usage_output_tokens",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "purple", "value": null }] },
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [{ "expr": "sum(sum_over_time({service_name=~\"$service\"} | gen_ai_usage_output_tokens != \"\" | unwrap gen_ai_usage_output_tokens [$__range]))", "legendFormat": "", "refId": "A" }]
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 5 },
      "id": 3,
      "type": "stat",
      "title": "Total Inference Calls",
      "description": "Number of gen_ai.client.inference events",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "orange", "value": null }] },
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [{ "expr": "sum(count_over_time({service_name=~\"$service\"} | event_name = `gen_ai.client.inference.operation.details` [$__range]))", "legendFormat": "", "refId": "A" }]
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 5 },
      "id": 4,
      "type": "stat",
      "title": "Total Agent Turns",
      "description": "Number of copilot_chat.agent.turn events",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [{ "expr": "sum(count_over_time({service_name=~\"$service\"} | event_name = `copilot_chat.agent.turn` [$__range]))", "legendFormat": "", "refId": "A" }]
    },

    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 10,
      "type": "timeseries",
      "title": "Token Usage Over Time",
      "description": "Input and output token consumption over time",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never" },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Input Tokens" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Output Tokens" }, "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "sum(sum_over_time({service_name=~\"$service\"} | gen_ai_usage_input_tokens != \"\" | unwrap gen_ai_usage_input_tokens [$__auto]))", "legendFormat": "Input Tokens", "refId": "A" },
        { "expr": "sum(sum_over_time({service_name=~\"$service\"} | gen_ai_usage_output_tokens != \"\" | unwrap gen_ai_usage_output_tokens [$__auto]))", "legendFormat": "Output Tokens", "refId": "B" }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 11,
      "type": "piechart",
      "title": "Inference Calls by AI Model",
      "description": "Distribution of inference events across AI models",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }, "tooltip": { "mode": "multi" }, "pieType": "donut", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [{ "expr": "sum by (gen_ai_request_model) (count_over_time({service_name=~\"$service\"} | gen_ai_request_model != \"\" [$__range]))", "legendFormat": "{{gen_ai_request_model}}", "refId": "A" }]
    },

    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "id": 12,
      "type": "piechart",
      "title": "Events by Type",
      "description": "Distribution of event types: inference, agent turns, tool calls",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }, "tooltip": { "mode": "multi" }, "pieType": "donut", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [{ "expr": "sum by (event_name) (count_over_time({service_name=~\"$service\"} | event_name != \"\" [$__range]))", "legendFormat": "{{event_name}}", "refId": "A" }]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "id": 13,
      "type": "barchart",
      "title": "Token Usage by Model",
      "description": "Input and output token consumption per AI model",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*input.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": ".*output.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" }, "orientation": "horizontal", "stacking": "normal", "barWidth": 0.8, "groupWidth": 0.7 },
      "targets": [
        { "expr": "sum by (gen_ai_request_model) (sum_over_time({service_name=~\"$service\"} | gen_ai_request_model != \"\" | gen_ai_usage_input_tokens != \"\" | unwrap gen_ai_usage_input_tokens [$__range]))", "legendFormat": "input: {{gen_ai_request_model}}", "refId": "A" },
        { "expr": "sum by (gen_ai_request_model) (sum_over_time({service_name=~\"$service\"} | gen_ai_request_model != \"\" | gen_ai_usage_output_tokens != \"\" | unwrap gen_ai_usage_output_tokens [$__range]))", "legendFormat": "output: {{gen_ai_request_model}}", "refId": "B" }
      ]
    },

    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 25 },
      "id": 109,
      "type": "text",
      "title": "",
      "options": { "mode": "markdown", "content": "---\n### Tool Call Analytics\nInsights into Copilot tool invocations — which tools are used, success rates, and durations." }
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 27 },
      "id": 60,
      "type": "stat",
      "title": "Total Tool Calls",
      "description": "Number of copilot_chat.tool.call events",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] },
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [{ "expr": "sum(count_over_time({service_name=~\"$service\"} | event_name = `copilot_chat.tool.call` [$__range]))", "legendFormat": "", "refId": "A" }]
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 27 },
      "id": 61,
      "type": "stat",
      "title": "Failed Tool Calls",
      "description": "Tool calls where success=false",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 10 }] },
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [{ "expr": "sum(count_over_time({service_name=~\"$service\"} | event_name = `copilot_chat.tool.call` | success = `false` [$__range]))", "legendFormat": "", "refId": "A" }]
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 27 },
      "id": 62,
      "type": "stat",
      "title": "Avg Tool Duration",
      "description": "Average tool call duration in ms",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5000 }, { "color": "red", "value": 30000 }] },
          "unit": "ms",
          "noValue": "N/A"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["mean"] } },
      "targets": [{ "expr": "avg_over_time({service_name=~\"$service\"} | event_name = `copilot_chat.tool.call` | duration_ms != \"\" | unwrap duration_ms [$__range])", "legendFormat": "", "refId": "A" }]
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 27 },
      "id": 63,
      "type": "stat",
      "title": "Avg Tool Calls / Turn",
      "description": "Average tool_call_count per agent turn",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "short",
          "noValue": "N/A"
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["mean"] } },
      "targets": [{ "expr": "avg_over_time({service_name=~\"$service\"} | event_name = `copilot_chat.agent.turn` | tool_call_count != \"\" | unwrap tool_call_count [$__range])", "legendFormat": "", "refId": "A" }]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "id": 64,
      "type": "piechart",
      "title": "Tool Calls by Tool Name",
      "description": "Distribution of Copilot tool invocations",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }, "tooltip": { "mode": "multi" }, "pieType": "donut", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [{ "expr": "sum by (gen_ai_tool_name) (count_over_time({service_name=~\"$service\"} | event_name = `copilot_chat.tool.call` | gen_ai_tool_name != \"\" [$__range]))", "legendFormat": "{{gen_ai_tool_name}}", "refId": "A" }]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "id": 65,
      "type": "timeseries",
      "title": "Tool Call Rate Over Time",
      "description": "Frequency of tool invocations over time by tool name",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never", "stacking": { "mode": "normal" } },
          "unit": "short"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "expr": "sum by (gen_ai_tool_name) (count_over_time({service_name=~\"$service\"} | event_name = `copilot_chat.tool.call` | gen_ai_tool_name != \"\" [$__auto]))", "legendFormat": "{{gen_ai_tool_name}}", "refId": "A" }]
    },

    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 39 },
      "id": 102,
      "type": "text",
      "title": "",
      "options": { "mode": "markdown", "content": "---\n### Performance Deep-Dive" }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "id": 20,
      "type": "timeseries",
      "title": "Latency Percentiles by Operation",
      "description": "P50 / P95 / P99 latency grouped by Copilot operation",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" },
          "unit": "s"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le, span_name) (rate(traces_spanmetrics_latency_bucket{service=~\"$service\"}[$__rate_interval])))", "legendFormat": "P50 {{span_name}}", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le, span_name) (rate(traces_spanmetrics_latency_bucket{service=~\"$service\"}[$__rate_interval])))", "legendFormat": "P95 {{span_name}}", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le, span_name) (rate(traces_spanmetrics_latency_bucket{service=~\"$service\"}[$__rate_interval])))", "legendFormat": "P99 {{span_name}}", "refId": "C" }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "id": 21,
      "type": "heatmap",
      "title": "Latency Distribution Heatmap",
      "description": "Heatmap of span latencies — identify clusters and outliers",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": {
        "calculate": false,
        "yAxis": { "unit": "s" },
        "color": { "mode": "scheme", "scheme": "Oranges" },
        "cellGap": 1,
        "tooltip": { "show": true }
      },
      "targets": [{ "expr": "sum(increase(traces_spanmetrics_latency_bucket{service=~\"$service\"}[$__rate_interval])) by (le)", "legendFormat": "{{le}}", "refId": "A", "format": "heatmap" }]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 49 },
      "id": 22,
      "type": "timeseries",
      "title": "Throughput vs Latency Correlation",
      "description": "Overlays event rate with average latency to spot saturation",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "axisBorderShow": false }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Event Rate" }, "properties": [{ "id": "unit", "value": "ops" }, { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }, { "id": "custom.axisPlacement", "value": "left" }] },
          { "matcher": { "id": "byName", "options": "Avg Latency" }, "properties": [{ "id": "unit", "value": "s" }, { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }, { "id": "custom.axisPlacement", "value": "right" }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum(rate(traces_spanmetrics_calls_total{service=~\"$service\"}[$__rate_interval]))", "legendFormat": "Event Rate", "refId": "A" },
        { "expr": "sum(rate(traces_spanmetrics_latency_sum{service=~\"$service\"}[$__rate_interval])) / sum(rate(traces_spanmetrics_latency_count{service=~\"$service\"}[$__rate_interval]))", "legendFormat": "Avg Latency", "refId": "B" }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 49 },
      "id": 23,
      "type": "timeseries",
      "title": "Span Rate by Kind",
      "description": "Event rate grouped by span kind (client, server, internal)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never" },
          "unit": "ops"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "sum"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "sum by (span_kind) (rate(traces_spanmetrics_calls_total{service=~\"$service\"}[$__rate_interval]))", "legendFormat": "{{span_kind}}", "refId": "A" }
      ]
    },

    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 57 },
      "id": 103,
      "type": "text",
      "title": "",
      "options": { "mode": "markdown", "content": "---\n### Error Intelligence" }
    },
    {
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 59 },
      "id": 30,
      "type": "stat",
      "title": "Error Rate %",
      "description": "Percentage of span events with error status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] },
          "unit": "percent",
          "noValue": "0%",
          "max": 100,
          "min": 0
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "(sum(increase(traces_spanmetrics_calls_total{service=~\"$service\", status_code=\"STATUS_CODE_ERROR\"}[$__range])) / sum(increase(traces_spanmetrics_calls_total{service=~\"$service\"}[$__range]))) * 100 OR vector(0)", "legendFormat": "", "refId": "A" }]
    },
    {
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 59 },
      "id": 31,
      "type": "stat",
      "title": "Failed Tool Calls",
      "description": "Tool calls with success=false from logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 10 }] },
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [{ "expr": "sum(count_over_time({service_name=~\"$service\"} | event_name = `copilot_chat.tool.call` | success = `false` [$__range]))", "legendFormat": "", "refId": "A" }]
    },
    {
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 59 },
      "id": 32,
      "type": "stat",
      "title": "Error Spans Total",
      "description": "Total span events with STATUS_CODE_ERROR",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 20 }] },
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
